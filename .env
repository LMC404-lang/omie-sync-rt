# Sync settings
SYNC_INTERVAL_HOURS=3          # How often to run incremental sync
FULL_SYNC_CRON=0 2 * * *       # Full sync cron (default: 2am daily)
BATCH_SIZE=200                  # Records per Supabase upsert batch
OMIE_PAGE_SIZE=50               # Records per Omie API page
OMIE_REQUEST_DELAY_MS=300       # Delay between Omie API pages (rate limiting)
OMIE_MAX_RETRIES=3              # Retry attempts on API failure
OMIE_REQUEST_TIMEOUT_MS=60000   # Per-request HTTP timeout (NF-e and big lists need >30s)

# Generic table registry (config/omie-tables.js)
# Comma-separated list of tiers to include in every run.
#   critical   → Phase 1 essentials (DRE, categories, units, vendors, …)
#   important  → CRM lookups, banks, payment methods, parcelas, …
#   optional   → buyers, stock, inventory, purchases, NF-e, NFS-e, boletos, PIX, …
#   industry   → Phase 7 industry-specific tables (variations, kits, lots, BOM, OPs, contracts, CT-e, NFC-e, tags, custom fields)
#   all        → enable everything regardless of tier
OMIE_SYNC_TIERS=critical,important,optional

# Logging
LOG_LEVEL=info                  # debug | info | warn | error
LOG_DIR=./logs
